{
  "name": "migrador-titulos",
  "version": "2.0.3",
  "description": "Migración automática desde Excel hacia Firestore titulos-ec2fa.",
  "main": "bootstrap.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis portable"
  },
  "dependencies": {
    "firebase-admin": "13.4.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "electron": "43.2.0",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "ec.edu.itsqmet.migrador.titulos",
    "productName": "Migrador de Títulos",
    "asar": true,
    "files": [
      "bootstrap.js",
      "main.js",
      "preload.js",
      "index.html",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Migrador de Títulos",
      "artifactName": "MigradorTitulos-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "MigradorTitulos-Portable-${version}-${arch}.${ext}"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
